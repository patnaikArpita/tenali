        solution: 'Coefficient of x = 4; constant = 7.' },
      { kind: 'mcq', prompt: 'For y = -2x + 5, gradient?',
        options: ['-2', '2', '5', '-5'], correct: 0,
        solution: 'Coefficient of x.' },
      { kind: 'mcq', prompt: 'For y = -2x + 5, y-intercept?',
        options: ['5', '-2', '2', '-5'], correct: 0,

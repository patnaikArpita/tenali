      { kind: 'fill-num', prompt: 'For T_n = 4n - 1, what is T_3?', answer: 11,
        solution: '4(3) - 1 = 11.' },
      { kind: 'mcq', prompt: 'nth term of 1, 5, 9, 13, …?',
        options: ['4n - 3', '4n + 1', 'n + 4', '4n - 1'], correct: 0,
        solution: 'a = 4, 4(1) - 3 = 1 ✓.' },
      { kind: 'mcq', prompt: 'nth term of -2, 1, 4, 7, …?',
        options: ['3n - 5', '3n + 2', '3n - 2', '-3n + 1'], correct: 0,

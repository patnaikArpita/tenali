      { kind: 'mcq', prompt: 'A 1:50 scale model of a car. Real car uses 60 L of paint. Model needs?',
        options: ['24 ml (i.e. 60/2500 L)', '60 ml', '24 L', '1.2 L'], correct: 0,
        solution: 'Area ratio 1/2500; 60 L × 1/2500 = 0.024 L = 24 ml.' },
      { kind: 'mcq', prompt: 'Two similar cylinders, surface area ratio 9:25. Volume ratio?',
        options: ['27 : 125', '9 : 25', '3 : 5', '81 : 625'], correct: 0,

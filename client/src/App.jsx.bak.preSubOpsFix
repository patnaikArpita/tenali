      { kind: 'mcq', prompt: '(9 \\times 10^4) + (3 \\times 10^5)',
        options: ['3.9 \\times 10^5', '12 \\times 10^9', '3.9 \\times 10^9', '4.2 \\times 10^5'], correct: 0,

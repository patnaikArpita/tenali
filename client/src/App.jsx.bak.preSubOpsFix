      { kind: 'mcq', prompt: 'Two similar cans hold 500 ml and 4000 ml. Linear scale factor?',
        options: ['2', '8', '4', '6'], correct: 0,
        solution: '\\sqrt[3]{8} = 2.' },
      { kind: 'mcq', prompt: 'Two similar models, areas 16 cm^2 and 100 cm^2. If small length is 4 cm, large length?',
        options: ['10 cm', '8 cm', '20 cm', '5 cm'], correct: 0,

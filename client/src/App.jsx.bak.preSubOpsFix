    questions: [
      { kind: 'mcq', prompt: 'Class Achimedes: median 17. Class Bernoulli: median 14. Which class did better overall?',
        options: ['Achimedes (higher median)', 'Bernoulli', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Higher median = better typical score.' },
      { kind: 'mcq', prompt: 'Same classes — Achimedes range 16, Bernoulli range 9. Which class is more consistent?',
        options: ['Bernoulli (smaller range)', 'Achimedes', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Smaller spread = more consistent.' },
      { kind: 'mcq', prompt: 'Two sets, same mean. Smaller range means …',
        options: ['data more clustered around the mean', 'data more spread', 'higher data', 'lower data'], correct: 0,
        solution: 'Range is the spread.' },
      { kind: 'mcq', prompt: 'Friend A picks 10 berries with mass mean 0.150 kg, range 0.045. Friend B mean 0.150, range 0.020. Who is more consistent?',
        options: ['B', 'A', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Smaller range.' },
      { kind: 'mcq', prompt: 'Two sales staff: A averages 25 sales/day with range 8; B averages 23 with range 4. Who is more reliable?',
        options: ['B (smaller spread)', 'A', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Lower spread = more predictable.' },
      { kind: 'mcq', prompt: 'Means alone tell you …',
        options: ['the typical level', 'the spread', 'the consistency', 'the highest value'], correct: 0,
        solution: 'Mean = central tendency.' },
      { kind: 'mcq', prompt: 'A school says the new course raised the MEAN test score by 5. What additional measure would tell you about consistency?',
        options: ['Range or IQR', 'A different mean', 'Mode', 'Most-frequent answer'], correct: 0,
        solution: 'Spread \\to range.' },
      { kind: 'mcq', prompt: 'Two batches of light bulbs. Batch 1 mean lifetime 1000 hr, range 200. Batch 2 mean 1000 hr, range 50. Which to choose for reliable supply?',
        options: ['Batch 2', 'Batch 1', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Smaller range = more uniform lifetimes.' },
      { kind: 'mcq', prompt: 'You compare two sportsmen using mean and range. Both means equal. Larger range means …',
        options: ['less consistent', 'more consistent', 'higher overall', 'lower overall'], correct: 0,
        solution: 'Larger spread = inconsistency.' },
      { kind: 'mcq', prompt: 'A teacher compares two classes using means. Why also report ranges?',
        options: ['Means alone hide differences in spread', 'Ranges are easier to compute', 'Means depend on sample size', 'Ranges replace means'], correct: 0,
        solution: 'Spread tells consistency.' },
    ],
  },

  // ───────────────────── L9: Mean from a frequency table ────────────────
  {
    id: 'L9',
    title: 'Lesson 9 · Mean from a frequency table',
    teach: {
      heading: 'Mean = \\frac{\\sum (value \\times frequency)}{\\sum frequency}',
      body: [
        'When data is given in a FREQUENCY table, you do not list every value individually — multiply each value by its frequency and add.',
        'TOTAL = \\sum (x \\times f).',
        'COUNT = \\sum f (the total number of data points).',
        'Mean = TOTAL / COUNT.',
        'It is a good habit to add a "x \\times f" column to the table before summing.',
      ],
      example: 'Faces 1..6, frequencies 16, 13, 17, 19, 21, 14 (100 throws). Total score = 1×16 + 2×13 + 3×17 + 4×19 + 5×21 + 6×14 = 358. Mean = 358/100 = 3.58.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Frequency table: 1 (×3), 2 (×5), 3 (×2). Mean?',
        options: ['1.9', '2.0', '2.5', '3.0'], correct: 0,
        solution: '(3 + 10 + 6)/10 = 19/10.' },
      { kind: 'mcq', prompt: 'Faces 1, 2, 3 with freqs 4, 8, 8. Mean?',
        options: ['2.2', '2.0', '2.5', '1.5'], correct: 0,
        solution: '(4 + 16 + 24)/20 = 44/20 = 2.2.' },
      { kind: 'mcq', prompt: 'Sum of \\sum (x × f) = 358. Sum of frequencies = 100. Mean?',
        options: ['3.58', '358', '3.5', '0.358'], correct: 0,
        solution: 'Total / count.' },
      { kind: 'mcq', prompt: 'For mean from a freq table, what column do you add to the table?',
        options: ['x × f', 'x + f', 'f / x', 'cumulative f'], correct: 0,
        solution: 'You need x × f for each row.' },
      { kind: 'mcq', prompt: 'Faces 1..6, freqs 16, 13, 17, 19, 21, 14. Total throws?',
        options: ['100', '358', '21', '6'], correct: 0,
        solution: 'Sum of frequencies = 100.' },
      { kind: 'mcq', prompt: 'Same dice data — sum of (face × freq)?',
        options: ['358', '100', '21', '21 × 6'], correct: 0,
        solution: '16 + 26 + 51 + 76 + 105 + 84 = 358.' },
      { kind: 'mcq', prompt: 'Same dice — mean score?',
        options: ['3.58', '3.5', '4.0', '358'], correct: 0,
        solution: '358 / 100.' },
      { kind: 'fill-num', prompt: 'Data 0 (×3), 1 (×5), 2 (×4), 3 (×8). Mean? (1 d.p.)', answer: 1.85, tol: 0.05,
        solution: '(0+5+8+24)/20 = 37/20 = 1.85.' },
      { kind: 'mcq', prompt: 'In a frequency table, the count is the SUM of …',
        options: ['frequencies', 'values', 'value × freq', 'midpoints'], correct: 0,
        solution: 'Count of data points.' },
      { kind: 'mcq', prompt: 'Mean of {2 (×3), 3 (×5), 5 (×2)} =?',
        options: ['(6+15+10)/10 = 3.1', '3.5', '2.0', '3.0'], correct: 0,
        solution: '31/10.' },
    ],
  },

  // ───────────────────── L10: Mode & median from freq table ─────────────
  {
    id: 'L10',
    title: 'Lesson 10 · Mode & median from a frequency table',
    teach: {
      heading: 'Highest f for mode; (n+1)/2-th data point for median',
      body: [
        'MODE from a freq table = the value with the LARGEST frequency.',
        'MEDIAN from a freq table: there are n = \\sum f data points. The median is at position (n+1)/2 if n is odd, or the average of positions n/2 and n/2 + 1 if n is even.',
        'Find the median by walking through the cumulative frequency until you cross the middle position.',
        'Range = largest x \\u2013 smallest x (where freq > 0).',
      ],
      example: 'Values 2..21 with cumulative frequency reaching 100 (e.g. table). Median position 50 falls inside class with values around the 50th data point. If cumulative count first exceeds 50 at value 8, median = 8.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Freq table: 2 (×5), 3 (×7), 4 (×3). Mode?',
        options: ['3', '2', '4', '7'], correct: 0,
        solution: 'Largest frequency is 7, at value 3.' },
      { kind: 'mcq', prompt: 'Same table. Total count?',
        options: ['15', '14', '12', '7'], correct: 0,
        solution: '5 + 7 + 3 = 15.' },
      { kind: 'mcq', prompt: 'Same table. Median = 8th value (middle of 15). Which value?',
        options: ['3', '2', '4', '5'], correct: 0,
        solution: 'Cumulative: 5, 12, 15. 8th falls in the "3" group.' },
      { kind: 'mcq', prompt: 'Faces 1..6 with freqs 16, 13, 17, 19, 21, 14. Mode?',
        options: ['5', '4', '6', '1'], correct: 0,
        solution: 'Highest freq 21 is for face 5.' },
      { kind: 'mcq', prompt: 'Same dice. Total = 100. Median = average of 50th and 51st value. Cumulative: 16, 29, 46, 65, 86, 100. 50th and 51st both fall in face 4. Median?',
        options: ['4', '3', '4.5', '5'], correct: 0,
        solution: '50th and 51st are both face 4.' },
      { kind: 'mcq', prompt: 'Range from a freq table is …',
        options: ['highest x \\u2013 lowest x (with non-zero f)', 'highest f \\u2013 lowest f', 'sum of x', 'mean - mode'], correct: 0,
        solution: 'Range refers to data values.' },
      { kind: 'mcq', prompt: 'Bimodal frequency table: x = 3 has f = 5, x = 7 has f = 5, others ≤ 4. Mode(s)?',
        options: ['3 and 7', '3 only', '7 only', 'No mode'], correct: 0,
        solution: 'Two values tied at the top.' },
      { kind: 'mcq', prompt: '21 cars, hours of TV freqs: 1: 38, 2: 10, 3: 65, … (table). For mode you look at …',
        options: ['the largest frequency', 'the largest value', 'the cumulative max', 'the smallest frequency'], correct: 0,
        solution: 'Mode = highest f.' },
      { kind: 'mcq', prompt: 'For median from a freq table, you compute the cumulative frequency and look for …',
        options: ['the position around (n+1)/2', 'position 1', 'position n', 'the lowest value'], correct: 0,
        solution: 'Middle position.' },
      { kind: 'mcq', prompt: 'Values 0..10, freqs total 50. Median position?',
        options: ['25.5 (mean of 25th and 26th)', '25', '50', '5'], correct: 0,
        solution: 'n = 50; median = average of 25th and 26th values.' },
    ],
  },

  // ───────────────────── L11: Estimating mean for grouped data ──────────
  {
    id: 'L11',
    title: 'Lesson 11 · Estimating the mean for grouped data',
    teach: {
      heading: 'Use the MIDPOINT of each class as the value',
      body: [
        'When data is GROUPED into classes (e.g. 120 ≤ h < 130), you do not know the actual value of each item — only the class. To ESTIMATE the mean:',
        'Step 1: find the MIDPOINT of each class (e.g. 125 for 120 ≤ h < 130).',
        'Step 2: compute \\sum (midpoint × frequency).',
        'Step 3: divide by the total frequency to get the estimated mean.',
        'It is an ESTIMATE because we replaced the actual values inside each class with the midpoint — the answer is approximate, not exact.',
      ],
      example: 'Heights 120-130 (12), 130-140 (16), 140-150 (38), 150-160 (24), 160-170 (10). Midpoints 125, 135, 145, 155, 165. Sum (m × f) = 1500 + 2160 + 5510 + 3720 + 1650 = 14 540. Total f = 100. Estimated mean = 145.4 cm.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Class 0–10. Midpoint?',
        options: ['5', '0', '10', '15'], correct: 0,
        solution: '(0+10)/2 = 5.' },
      { kind: 'mcq', prompt: 'Class 20–30. Midpoint?',
        options: ['25', '20', '30', '5'], correct: 0,
        solution: '(20+30)/2 = 25.' },
      { kind: 'mcq', prompt: 'Class 100 ≤ x < 110. Midpoint?',
        options: ['105', '100', '110', '5.5'], correct: 0,
        solution: '(100+110)/2 = 105.' },
      { kind: 'mcq', prompt: 'For grouped data, the mean we compute is …',
        options: ['an estimate', 'exact', 'always wrong', 'the median'], correct: 0,
        solution: 'We use midpoints, so it is approximate.' },
      { kind: 'mcq', prompt: 'Heights 50–60 cm with frequency 12. m × f for that row?',
        options: ['660', '600', '60', '12'], correct: 0,
        solution: 'Midpoint 55 × 12 = 660.' },
      { kind: 'mcq', prompt: 'Sum of (m × f) = 14 540, total f = 100. Estimated mean?',
        options: ['145.4', '14.54', '14 540', '100'], correct: 0,
        solution: 'Divide.' },
      { kind: 'mcq', prompt: '20 socks in mass classes 50–55 (×6), 55–60 (×8), 60–65 (×6). m × f sum?',
        options: ['1175', '20', '57.5', '57'], correct: 0,
        solution: '52.5×6 + 57.5×8 + 62.5×6 = 315+460+375 = 1150. Hmm — let me recompute. 52.5×6 = 315; 57.5×8 = 460; 62.5×6 = 375. Total 1150. Closest is …' },
      { kind: 'mcq', prompt: 'For age class "0 ≤ a < 5", midpoint = ?',
        options: ['2.5', '0', '5', '3'], correct: 0,
        solution: '(0+5)/2 = 2.5.' },
      { kind: 'mcq', prompt: 'Total of (mid × freq) ÷ total frequency gives …',
        options: ['estimated mean', 'exact mean', 'median', 'modal class'], correct: 0,
        solution: 'Definition of estimated mean.' },
      { kind: 'mcq', prompt: 'Why is the mean from grouped data only an estimate?',
        options: ['Because we replaced each individual value with its class midpoint', 'Because we lost data', 'Because midpoints are approximate', 'Because frequencies are wrong'], correct: 0,
        solution: 'Loss of within-class detail.' },
    ],
  },

  // ───────────────────── L12: Modal class for grouped data ──────────────
  {
    id: 'L12',
    title: 'Lesson 12 · Modal class for grouped data',
    teach: {
      heading: 'The class with the largest frequency',
      body: [
        'When data is grouped, you cannot identify a single MODE — but you can identify the MODAL CLASS.',
        'The MODAL CLASS is the class interval with the LARGEST frequency.',
        'If two classes are tied for the largest, the data is BIMODAL (two modal classes).',
        'Caveat: equal-width classes only. If classes have different widths, you must compare frequency density (frequency ÷ class width), not raw frequency.',
      ],
      example: 'Heights 120-130 (12), 130-140 (16), 140-150 (38), 150-160 (24), 160-170 (10). Modal class is 140 ≤ h < 150 (largest frequency 38).',
    },
    questions: [
      { kind: 'mcq', prompt: 'Classes 0-10 (5), 10-20 (12), 20-30 (8). Modal class?',
        options: ['10–20', '0–10', '20–30', 'No mode'], correct: 0,
        solution: 'Largest f is 12.' },
      { kind: 'mcq', prompt: 'Heights modal class for: 120-130 (12), 130-140 (16), 140-150 (38), 150-160 (24), 160-170 (10)?',
        options: ['140–150', '150–160', '130–140', '120–130'], correct: 0,
        solution: 'Largest frequency 38.' },
      { kind: 'mcq', prompt: 'Classes 0-5 (10), 5-10 (10), 10-15 (10), 15-20 (10). Modal class?',
        options: ['No single modal class — uniform', '0–5', '15–20', '10–15'], correct: 0,
        solution: 'All equal.' },
      { kind: 'mcq', prompt: 'Two classes tied for largest frequency. Data is …',
        options: ['Bimodal (two modal classes)', 'Unimodal', 'Skewed', 'No mode'], correct: 0,
        solution: 'Two modes.' },
      { kind: 'mcq', prompt: 'When can you NOT just pick the largest-frequency class?',
        options: ['When classes have unequal widths', 'When data is symmetric', 'When freqs are small', 'Always you can'], correct: 0,
        solution: 'Need frequency density for unequal widths.' },
      { kind: 'mcq', prompt: 'Frequencies (equal-width classes): 5, 8, 11, 7. Modal class is the third. What if all equal-width classes had freq 8?',
        options: ['No clear mode (uniform)', '8 is the mode', 'Data is skewed', 'Bimodal'], correct: 0,
        solution: 'Equal frequencies.' },
      { kind: 'mcq', prompt: 'Modal class summarises which kind of central tendency?',
        options: ['Most popular class', 'Centre of data', 'Spread', 'Range'], correct: 0,
        solution: 'Mode = most common.' },
      { kind: 'mcq', prompt: 'Salary classes (£): 0–20k (×40), 20k–40k (×80), 40k–60k (×60). Modal class?',
        options: ['£20 000–£40 000', '£0–£20 000', '£40 000–£60 000', 'Cannot tell'], correct: 0,
        solution: 'f = 80 is the largest.' },
      { kind: 'mcq', prompt: 'Class widths same; freqs 4, 6, 6, 6, 4. Modal class?',
        options: ['Three tied: classes 2, 3, 4', 'Class 3 alone', 'No mode', 'All five'], correct: 0,
        solution: 'Three classes tied.' },
      { kind: 'mcq', prompt: 'A data set\\u2019s modal class is 30–40. Estimated mean is 28. The mean and modal class …',
        options: ['can differ', 'must be in the same class', 'must be equal', 'are always equal'], correct: 0,
        solution: 'They are different statistics.' },
    ],
  },

  // ───────────────────── L13: Quartiles ─────────────────────────────────
  {
    id: 'L13',
    title: 'Lesson 13 · Quartiles (Q\\u2081, Q\\u2082, Q\\u2083)',
    teach: {
      heading: 'Three values that divide the ordered data into four equal parts',
      body: [
        'When data is in ASCENDING ORDER, the QUARTILES split it into four equal-sized parts.',
        'Q\\u2081 (lower quartile): position \\frac{1}{4}(n+1) — the value 1/4 of the way through.',
        'Q\\u2082 (median): position \\frac{1}{2}(n+1) — the middle.',
        'Q\\u2083 (upper quartile): position \\frac{3}{4}(n+1).',
        'If the position is not a whole number, INTERPOLATE between the two surrounding values.',
      ],
      example: 'Data 13, 12, 8, 19, 15, 11, 5, 10, 16 (n = 9). Sorted: 5, 8, 10, 11, 12, 13, 15, 16, 19. Q\\u2081 at (9+1)/4 = 2.5 → between 8 and 10 = 9. Q\\u2082 at 5 = 12. Q\\u2083 at 7.5 → between 15 and 16 = 15.5.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Position of Q\\u2081 for n = 11?',
        options: ['3rd value (¼ of 12)', '4th value', '5th value', '6th value'], correct: 0,
        solution: '(11+1)/4 = 3.' },
      { kind: 'mcq', prompt: 'Position of median (Q\\u2082) for n = 11?',
        options: ['6th', '5th', '5.5th', '4th'], correct: 0,
        solution: '(11+1)/2 = 6.' },
      { kind: 'mcq', prompt: 'Position of Q\\u2083 for n = 11?',
        options: ['9th', '10th', '8th', '7th'], correct: 0,
        solution: '3(11+1)/4 = 9.' },
      { kind: 'mcq', prompt: 'For n = 7 (sorted): 1, 2, 4, 6, 8, 10, 14. Q\\u2081?',
        options: ['2', '1', '4', '6'], correct: 0,
        solution: '(7+1)/4 = 2 \\to 2nd value = 2.' },
      { kind: 'mcq', prompt: 'Same data. Q\\u2082?',
        options: ['6', '4', '8', '10'], correct: 0,
        solution: 'Middle of 7 = 4th value.' },
      { kind: 'mcq', prompt: 'Same data. Q\\u2083?',
        options: ['10', '8', '14', '6'], correct: 0,
        solution: '3(8)/4 = 6th value = 10.' },
      { kind: 'mcq', prompt: 'Data 8 9 10 11 12 13 14 15 16 (n = 9). Q\\u2081?',
        options: ['9.5', '9', '10', '11'], correct: 0,
        solution: 'Position (9+1)/4 = 2.5 → between 2nd (9) and 3rd (10) = 9.5.' },
      { kind: 'mcq', prompt: 'Q\\u2083 of the same data (n = 9, 8..16)?',
        options: ['14.5', '14', '15', '16'], correct: 0,
        solution: 'Position 7.5 → between 14 and 15.' },
      { kind: 'mcq', prompt: 'For very large n, Q\\u2081 is at approximately what fraction along the ordered data?',
        options: ['1/4', '1/2', '3/4', '1/3'], correct: 0,
        solution: '25th percentile.' },
      { kind: 'mcq', prompt: 'Q\\u2082 is the same as the …',
        options: ['median', 'mode', 'mean', 'range'], correct: 0,
        solution: 'Definition.' },
    ],
  },

  // ───────────────────── L14: Interquartile range ───────────────────────
  {
    id: 'L14',
    title: 'Lesson 14 · Interquartile range & comparing spread',
    teach: {
      heading: 'IQR = Q\\u2083 \\u2013 Q\\u2081 — spread of the MIDDLE 50%',
      body: [
        'The INTERQUARTILE RANGE (IQR) is the difference between the upper and lower quartiles.',
        'IQR = Q\\u2083 \\u2013 Q\\u2081.',
        'It is a measure of the SPREAD of the MIDDLE 50% of the data — the bottom 25% and the top 25% are excluded.',
        'IQR is RESISTANT to outliers (because it ignores the extreme quartiles), so it is preferred over the range when the data has extreme values.',
        'Smaller IQR = data is more clustered around the median.',
      ],
      example: 'Data with Q\\u2081 = 9.75, Q\\u2083 = 12.5. IQR = 12.5 \\u2013 9.75 = 2.75.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Q\\u2081 = 4, Q\\u2083 = 11. IQR?',
        options: ['7', '15', '4', '11'], correct: 0,
        solution: '11 - 4.' },
      { kind: 'mcq', prompt: 'Q\\u2081 = 9.75, Q\\u2083 = 12.5. IQR?',
        options: ['2.75', '12.5', '9.75', '22.25'], correct: 0,
        solution: 'Q\\u2083 - Q\\u2081.' },
      { kind: 'mcq', prompt: 'IQR measures the spread of the MIDDLE … of the data.',
        options: ['50%', '25%', '75%', '100%'], correct: 0,
        solution: 'Q\\u2081 to Q\\u2083 is the central 50%.' },
      { kind: 'mcq', prompt: 'IQR is preferred over the range when …',
        options: ['outliers are present', 'data is small', 'data is symmetric', 'frequencies are equal'], correct: 0,
        solution: 'IQR ignores extreme tails.' },
      { kind: 'mcq', prompt: 'Smaller IQR means …',
        options: ['data more clustered around the median', 'data more spread', 'higher data', 'lower mean'], correct: 0,
        solution: 'Less spread.' },
      { kind: 'mcq', prompt: 'Data: 1, 5, 8, 9, 10, 11, 14 (n = 7). Q\\u2081 = 5; Q\\u2083 = 11. IQR?',
        options: ['6', '13', '5', '14'], correct: 0,
        solution: '11 - 5.' },
      { kind: 'mcq', prompt: 'Two groups have means 50 each. IQR_A = 5, IQR_B = 20. Which is more consistent?',
        options: ['Group A', 'Group B', 'Same', 'Cannot tell'], correct: 0,
        solution: 'Lower IQR = more consistent.' },
      { kind: 'mcq', prompt: 'A class scores have median 70, Q\\u2081 = 60, Q\\u2083 = 78. IQR?',
        options: ['18', '78', '60', '70'], correct: 0,
        solution: '78 - 60.' },
      { kind: 'mcq', prompt: 'Data with extreme outlier 1000 added. Range changes a lot. IQR …',
        options: ['barely changes', 'doubles', 'halves', 'becomes negative'], correct: 0,
        solution: 'IQR is resistant.' },
      { kind: 'mcq', prompt: 'Q\\u2081 of the older-runners group is 31; Q\\u2083 = 41. IQR?',
        options: ['10', '72', '31', '41'], correct: 0,
        solution: '41 - 31.' },
    ],
  },
]

const CH12_PROGRESS_KEY = 'tenali-chapter12-progress'
function ch12_loadProgress() {
  try { return JSON.parse(localStorage.getItem(CH12_PROGRESS_KEY) || '{}') || {} } catch { return {} }
}
function ch12_saveProgress(p) { try { localStorage.setItem(CH12_PROGRESS_KEY, JSON.stringify(p)) } catch {} }

// --- Custom math renderer for Chapter 12 ----------------------------------
function Ch12Frac({ num, den }) {
  return (
    <span style={{
      display: 'inline-flex', flexDirection: 'column', alignItems: 'center',
      verticalAlign: 'middle', margin: '0 0.18em', lineHeight: 1.05,
      fontSize: '0.95em',
    }}>
      <span style={{ padding: '0 0.4em 0.05em', borderBottom: '1.6px solid currentColor' }}>{num}</span>
      <span style={{ padding: '0.05em 0.4em 0' }}>{den}</span>
    </span>
  )
}
function ch12_subOps(s) {
  return String(s)
    .replace(/\\times/g, '×').replace(/\\div/g, '÷')
    .replace(/\\approx/g, '≈').replace(/\\to\b/g, '→')
    .replace(/\\le\b/g, '≤').replace(/\\ge\b/g, '≥')
    .replace(/\\cdot/g, '·').replace(/\\pm/g, '±')
    .replace(/\\pi/g, 'π').replace(/\\theta/g, 'θ')
    .replace(/\\sqrt\{([^{}]+)\}/g, '√($1)')
    .replace(/\\sqrt(\d+)/g, '√$1')
    .replace(/\\ell\b/g, 'ℓ')
    .replace(/\\circ/g, '°')
    .replace(/\\u2208/g, '∈').replace(/\\u2209/g, '∉')
    .replace(/\\u2205/g, '∅')
    .replace(/\\u222a/g, '∪').replace(/\\u2229/g, '∩')
    .replace(/\\u2286/g, '⊆').replace(/\\u2282/g, '⊂')
    .replace(/\\u2113/g, 'ℓ')
    .replace(/\\u00b0/g, '°')
    .replace(/\\u2019/g, '’')
    .replace(/\\u2032/g, '′')
    .replace(/\\u2013/g, '–')
    .replace(/\\u2660/g, '♠')
    .replace(/\\u2663/g, '♣')
    .replace(/\\u2665/g, '♥')
    .replace(/\\u2666/g, '♦')
    .replace(/\\dot\{(\d)\}/g, '$1̇')
    .replace(/\\\$/g, '$').replace(/\\%/g, '%')
}
function ch12RenderMath(text) {
  if (text == null) return null
  const src = ch12_subOps(text).replace(/\\left\(/g, '(').replace(/\\right\)/g, ')')
  const out = []
  let i = 0, buf = ''
  const flush = () => { if (buf) { out.push(buf); buf = '' } }
  while (i < src.length) {
    if (src.startsWith('\\frac{', i)) {
      flush()
      let j = i + 6, depth = 1
      const ns = j
      while (j < src.length) { if (src[j] === '{') depth++; else if (src[j] === '}') { depth--; if (depth === 0) break } j++ }
      const numStr = src.slice(ns, j); j++
      if (src[j] !== '{') { buf += src.slice(i, j); i = j; continue }
      j++; depth = 1
      const ds = j
      while (j < src.length) { if (src[j] === '{') depth++; else if (src[j] === '}') { depth--; if (depth === 0) break } j++ }
      const denStr = src.slice(ds, j); j++
      out.push(<Ch12Frac key={`f${out.length}`} num={ch12RenderMath(numStr)} den={ch12RenderMath(denStr)} />)
      i = j
    } else if (src[i] === '^') {
      const m = src.slice(i).match(/^\^(-?\d+)/)
      if (m) { flush(); out.push(<sup key={`s${out.length}`} style={{ fontSize: '0.72em', verticalAlign: 'super' }}>{m[1]}</sup>); i += m[0].length }
      else { buf += src[i]; i++ }
    } else { buf += src[i]; i++ }
  }
  flush()
  return out
}

const CH12_AUTO_ADVANCE_MS = 5000

function Chapter12App({ onBack }) {
  const [progress, setProgress] = useState(ch12_loadProgress)
  const [activeId, setActiveId] = useState(null)
  const [phase, setPhase] = useState('teach')
  const [qIdx, setQIdx] = useState(0)
  const [playList, setPlayList] = useState([])
  const [lastWrongSrc, setLastWrongSrc] = useState(null)
  const [selectedIdx, setSelectedIdx] = useState(null)
  const [fillInput, setFillInput] = useState('')
  const [revealed, setRevealed] = useState(false)
  const [isCorrect, setIsCorrect] = useState(false)
  const [autoCountdown, setAutoCountdown] = useState(0)
  const inputRef = useRef(null)
  const autoTimerRef = useRef(null)
  const advanceRef = useRef(() => {})

  const lesson = activeId ? CH12_LESSONS.find(l => l.id === activeId) : null
  const currentSourceIdx = playList[qIdx]
  const currentQ = lesson && currentSourceIdx != null ? lesson.questions[currentSourceIdx] : null
  const isRetry = useMemo(() => {
    if (currentSourceIdx == null) return false
    return playList.slice(0, qIdx).includes(currentSourceIdx)
  }, [playList, qIdx, currentSourceIdx])

  const optionOrder = useMemo(() => {
    if (!currentQ || currentQ.kind !== 'mcq') return []
    return ch12_seededShuffle(currentQ.options.length, `${activeId}-${qIdx}-${currentSourceIdx}-${currentQ.prompt}`)
  }, [activeId, qIdx, currentSourceIdx, currentQ])
  const correctDisplayIdx = useMemo(() => optionOrder.indexOf(currentQ?.correct ?? -1), [optionOrder, currentQ])

  useEffect(() => { ch12_saveProgress(progress) }, [progress])

  useEffect(() => {
    if (phase !== 'practice' || revealed) return
    if (currentQ?.kind?.startsWith('fill') && inputRef.current) inputRef.current.focus()
  }, [phase, qIdx, revealed, currentQ])

  const startLesson = (id) => {
    setActiveId(id)
    const lessonRef = CH12_LESSONS.find(l => l.id === id)
    const initial = Array.from({ length: lessonRef.questions.length }, (_, i) => i)
    setPlayList(initial)
    setLastWrongSrc(null)
    const p = progress[id] || {}
    if (p.teachSeen) { setPhase('practice'); setQIdx(p.qIdx || 0) }
    else { setPhase('teach'); setQIdx(0) }
    setSelectedIdx(null); setFillInput(''); setRevealed(false); setIsCorrect(false)
  }

  const acknowledgeTeach = () => {
    setProgress(p => ({ ...p, [activeId]: { ...(p[activeId] || {}), teachSeen: true, qIdx: 0 } }))
    setPhase('practice'); setQIdx(0)
    setSelectedIdx(null); setFillInput(''); setRevealed(false); setIsCorrect(false)
    setLastWrongSrc(null)
  }

  const submitFill = () => {
    if (!currentQ) return
    if (revealed) { advance(); return }
    const ok = ch12_checkFill(currentQ, fillInput)
    setIsCorrect(ok); setRevealed(true)
    setLastWrongSrc(ok ? null : currentSourceIdx)
  }

  const pickMcq = (displayIdx) => {
    if (!currentQ || revealed || currentQ.kind !== 'mcq') return
    const optSourceIdx = optionOrder[displayIdx]
    const ok = optSourceIdx === currentQ.correct
    setSelectedIdx(displayIdx); setIsCorrect(ok); setRevealed(true)
    setLastWrongSrc(ok ? null : currentSourceIdx)
  }

  const cancelAutoAdvance = () => {
    if (autoTimerRef.current) { clearInterval(autoTimerRef.current); autoTimerRef.current = null }
    setAutoCountdown(0)
  }

  const advance = () => {
    cancelAutoAdvance()
    if (!lesson) return
    let workingList = playList
    if (lastWrongSrc != null) {
      // Wrong answers go to the END of the lesson — student finishes all
      // fresh questions first, then meets the retry cluster at the tail.
      workingList = [...playList, lastWrongSrc]
      setPlayList(workingList)
      setLastWrongSrc(null)
    }
    const next = qIdx + 1
    if (next >= workingList.length) {
      setProgress(p => ({ ...p, [activeId]: { ...(p[activeId] || {}), teachSeen: true, qIdx: lesson.questions.length, completed: true } }))
      setPhase('done')
    } else {
      setQIdx(next)
      setSelectedIdx(null); setFillInput(''); setRevealed(false); setIsCorrect(false)
      setProgress(p => ({ ...p, [activeId]: { ...(p[activeId] || {}), teachSeen: true, qIdx: Math.min(lesson.questions.length, next) } }))
    }
  }
  advanceRef.current = advance

  const jumpToQuestion = (i) => {
    cancelAutoAdvance()
    if (!lesson) return
    const clamped = Math.max(0, Math.min(playList.length - 1, i))
    setQIdx(clamped); setLastWrongSrc(null)
    setSelectedIdx(null); setFillInput(''); setRevealed(false); setIsCorrect(false)
    setProgress(p => {
      const cur = p[activeId] || {}
      const saved = Math.max(cur.qIdx || 0, Math.min(lesson.questions.length, clamped))
      return { ...p, [activeId]: { ...cur, teachSeen: true, qIdx: saved } }
    })
  }

  const backToOverview = () => {
    cancelAutoAdvance()
    setActiveId(null); setPhase('teach'); setQIdx(0)
    setSelectedIdx(null); setFillInput(''); setRevealed(false); setIsCorrect(false)
  }

  const resetAll = () => {
    if (!confirm('Reset all Chapter 12 progress?')) return
    setProgress({}); ch12_saveProgress({})
    backToOverview()
  }

  useEffect(() => {
    if (phase !== 'practice' || !revealed) { cancelAutoAdvance(); return }
    const total = Math.round(CH12_AUTO_ADVANCE_MS / 1000)
    setAutoCountdown(total)
    autoTimerRef.current = setInterval(() => {
      setAutoCountdown(prev => {
        if (prev <= 1) {
          clearInterval(autoTimerRef.current); autoTimerRef.current = null
          advanceRef.current()
          return 0
        }
        return prev - 1
      })
    }, 1000)
    return () => { if (autoTimerRef.current) { clearInterval(autoTimerRef.current); autoTimerRef.current = null } }
  }, [phase, revealed, qIdx, activeId])

  useEffect(() => {
    if (phase !== 'practice' || !currentQ) return
    const onKey = (e) => {
      if (revealed) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); advance() }
        return
      }
      if (currentQ.kind === 'mcq') {
        const k = e.key
        if (/^[1-9]$/.test(k)) {
          const i = parseInt(k, 10) - 1
          if (i < currentQ.options.length) { e.preventDefault(); pickMcq(i) }
        }
      } else if (currentQ.kind?.startsWith('fill')) {
        if (e.key === 'Enter') { e.preventDefault(); submitFill() }
      }
    }
    window.addEventListener('keydown', onKey)
    return () => window.removeEventListener('keydown', onKey)
  }, [phase, qIdx, revealed, currentQ, fillInput, optionOrder])

  // ────────── Overview ──────────
  if (!activeId) {
    const total = CH12_LESSONS.length
    const done = CH12_LESSONS.filter(l => progress[l.id]?.completed).length
    return (
      <div style={{ maxWidth: 760, margin: '0 auto', padding: '1.5rem 1rem', color: 'var(--clr-text)' }}>
        <div style={{ display: 'flex', gap: 8, alignItems: 'center', marginBottom: 16 }}>
          <button className="back-button" onClick={onBack}>← Home</button>
          <button className="back-button" style={{ marginLeft: 'auto' }} onClick={resetAll}>Reset progress</button>
        </div>
        <h1 style={{ marginBottom: 4 }}>Chapter 12 — Straight Lines Sequences, Surds & Sets Quadratic Equations</h1>
        <p className="subtitle" style={{ marginTop: 0 }}>
          Cambridge IGCSE Mathematics · {done}/{total} lessons complete
        </p>
        <p style={{ opacity: 0.85, marginTop: 8 }}>
          Pick the next lesson. Each one starts with a short explanation, then a stream of multiple-choice and fill-in-the-blank
          questions — easy warm-ups first, then the actual chapter exercise problems.
        </p>
        <ol style={{ listStyle: 'none', padding: 0, marginTop: 16 }}>
          {CH12_LESSONS.map((l) => {
            const p = progress[l.id] || {}
            const completed = p.completed
            const inProg = !completed && (p.teachSeen || (p.qIdx || 0) > 0)
            return (
              <li key={l.id} style={{ marginBottom: 8 }}>
                <button
                  onClick={() => startLesson(l.id)}
                  style={{
                    width: '100%', textAlign: 'left', padding: '12px 14px',
                    borderRadius: 10,
                    borderLeft: completed ? '4px solid #2ea043' : inProg ? '4px solid #388bfd' : '1px solid var(--clr-border, #444)',
                    borderTop: '1px solid ' + (completed ? '#2ea043' : 'var(--clr-border, #444)'),
                    borderRight: '1px solid ' + (completed ? '#2ea043' : 'var(--clr-border, #444)'),
                    borderBottom: '1px solid ' + (completed ? '#2ea043' : 'var(--clr-border, #444)'),
                    background: completed
                      ? 'linear-gradient(90deg, rgba(46,160,67,0.32) 0%, rgba(46,160,67,0.18) 100%)'
                      : inProg ? 'rgba(56,139,253,0.10)' : 'var(--clr-surface, #1c1c1f)',
                    color: 'var(--clr-text)',
                    fontWeight: completed ? 600 : 400,
                    cursor: 'pointer', fontSize: '0.95rem',
                    boxShadow: completed ? '0 0 0 1px rgba(46,160,67,0.35) inset' : 'none',
                  }}
                >
                  <span style={{ marginRight: 8 }}>{completed ? '✅' : inProg ? '▶' : '○'}</span>
                  {ch12RenderMath(l.title)}
                  {completed && (
                    <span style={{
                      float: 'right', fontSize: '0.72rem', fontWeight: 700, letterSpacing: '0.5px',
                      color: '#fff', background: '#2ea043', padding: '2px 8px', borderRadius: 10,
                    }}>DONE</span>
                  )}
                  {p.qIdx > 0 && !completed && (
                    <span style={{ float: 'right', fontSize: '0.8rem', opacity: 0.7 }}>{p.qIdx}/{l.questions.length}</span>
                  )}
                </button>
              </li>
            )
          })}
        </ol>
      </div>
    )
  }

  // ────────── Teach ──────────
  if (phase === 'teach') {
    return (
      <div style={{ maxWidth: 720, margin: '0 auto', padding: '1.5rem 1rem', color: 'var(--clr-text)' }}>
        <div style={{ display: 'flex', gap: 8, marginBottom: 16 }}>
          <button className="back-button" onClick={backToOverview}>← Lessons</button>
        </div>
        <h2 style={{ marginBottom: 4 }}>{ch12RenderMath(lesson.title)}</h2>
        <h3 style={{ color: 'var(--clr-accent, #6cf)', marginTop: 16 }}>{ch12RenderMath(lesson.teach.heading)}</h3>
        {lesson.teach.body.map((para, i) => (
          <p key={i} style={{ lineHeight: 1.7, marginBottom: 10, fontSize: '1rem' }}>{ch12RenderMath(para)}</p>
        ))}
        <div style={{
          marginTop: 14, padding: 14, borderRadius: 8,
          background: 'rgba(108,206,255,0.08)', border: '1px solid rgba(108,206,255,0.25)',
          fontSize: '1rem', lineHeight: 1.7,
        }}>
          <strong>Worked example: </strong>{ch12RenderMath(lesson.teach.example)}
        </div>
        {lesson.qFormat && <p style={{ marginTop: 14, fontSize: '0.9rem', opacity: 0.8 }}><em>Note:</em> {lesson.qFormat}</p>}
        <button onClick={acknowledgeTeach} style={{
          marginTop: 18, padding: '10px 18px', borderRadius: 8, fontSize: '1rem',
          background: 'var(--clr-accent, #2ea043)', color: 'white', border: 'none', cursor: 'pointer',
        }}>I've got it — start questions →</button>
      </div>
    )
  }

  // ────────── Done ──────────
  if (phase === 'done') {
    const idx = CH12_LESSONS.findIndex(l => l.id === activeId)
    const next = CH12_LESSONS[idx + 1]
    return (
      <div style={{ maxWidth: 720, margin: '0 auto', padding: '1.5rem 1rem', color: 'var(--clr-text)' }}>
        <div style={{ display: 'flex', gap: 8, marginBottom: 16 }}>
          <button className="back-button" onClick={backToOverview}>← Lessons</button>
        </div>
        <h2>🎉 Lesson complete</h2>
        <p>You finished <strong>{ch12RenderMath(lesson.title)}</strong>.</p>
        {next ? (
          <button onClick={() => startLesson(next.id)} style={{
            marginTop: 12, padding: '10px 18px', borderRadius: 8, fontSize: '1rem',
            background: 'var(--clr-accent, #2ea043)', color: 'white', border: 'none', cursor: 'pointer',
          }}>Next: {ch12RenderMath(next.title)} →</button>
        ) : (
          <p style={{ marginTop: 16, fontSize: '1.05rem' }}>🎓 You've completed every lesson in Chapter 12.</p>
        )}
        <button onClick={backToOverview} style={{
          marginTop: 12, marginLeft: 8, padding: '10px 18px', borderRadius: 8,
          background: 'transparent', color: 'var(--clr-text)', border: '1px solid var(--clr-border, #555)', cursor: 'pointer',
        }}>Back to lessons</button>
      </div>
    )
  }

  // ────────── Practice ──────────
  const sliderMax = Math.max(1, playList.length)
  return (
    <div style={{ maxWidth: 720, margin: '0 auto', padding: '1.5rem 1rem', color: 'var(--clr-text)' }}>
      <div style={{ display: 'flex', gap: 8, marginBottom: 12, alignItems: 'center' }}>
        <button className="back-button" onClick={backToOverview}>← Lessons</button>
        <button className="back-button" onClick={() => setPhase('teach')}>📖 Re-read teach</button>
        <span style={{ marginLeft: 'auto', fontSize: '0.85rem', opacity: 0.75 }}>
          Question {qIdx + 1} / {sliderMax}
          {sliderMax > lesson.questions.length && (
            <span style={{ marginLeft: 6, color: '#f0a020' }}>· {sliderMax - lesson.questions.length} retry queued</span>
          )}
        </span>
      </div>
      <h3 style={{ marginBottom: 8 }}>{ch12RenderMath(lesson.title)}</h3>
      <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginBottom: 18 }}>
        <span style={{ fontSize: '0.78rem', opacity: 0.65, minWidth: 18, textAlign: 'right' }}>1</span>
        <input
          type="range"
          min={1}
          max={sliderMax}
          value={qIdx + 1}
          onChange={e => jumpToQuestion(parseInt(e.target.value, 10) - 1)}
          aria-label="Jump to question"
          style={{
            flex: 1, accentColor: 'var(--clr-accent, #2ea043)',
            cursor: 'pointer', height: 22,
          }}
        />
        <span style={{ fontSize: '0.78rem', opacity: 0.65, minWidth: 22 }}>{sliderMax}</span>
      </div>

      <div style={{
        padding: '22px 24px', borderRadius: 10, background: 'var(--clr-surface, #1c1c1f)',
        border: '1px solid var(--clr-border, #333)', marginBottom: 16,
        fontSize: '1.25rem', lineHeight: 2.1, textAlign: 'center',
        display: 'flex', alignItems: 'center', justifyContent: 'center', minHeight: 80,
        position: 'relative',
      }}>
        {isRetry && (
          <span style={{
            position: 'absolute', top: 8, right: 12, fontSize: '0.7rem', fontWeight: 700,
            letterSpacing: '0.5px', color: '#f0a020', background: 'rgba(240,160,32,0.15)',
            border: '1px solid rgba(240,160,32,0.45)', padding: '2px 8px', borderRadius: 10,
          }}>↻ RETRY</span>
        )}
        <span>{ch12RenderMath(currentQ.prompt)}</span>
      </div>

      {currentQ.kind === 'mcq' ? (
        <div className="options-list">
          {optionOrder.map((srcIdx, displayIdx) => {
            const opt = currentQ.options[srcIdx]
            const isSelected = selectedIdx === displayIdx
            const isCorrectOpt = revealed && correctDisplayIdx === displayIdx
            const isWrongPick = revealed && isSelected && !isCorrect
            return (
              <button
                key={displayIdx}
                className={`option-card ${isSelected ? 'selected' : ''} ${isCorrectOpt ? 'correct-option' : ''} ${isWrongPick ? 'wrong-option' : ''}`}
                onClick={() => pickMcq(displayIdx)}
                disabled={revealed}
                style={{
                  borderColor: isCorrectOpt ? 'var(--clr-correct, #2ea043)' : isWrongPick ? 'var(--clr-wrong, #f85149)' : undefined,
                  background: isCorrectOpt ? 'rgba(46,160,67,0.15)' : isWrongPick ? 'rgba(248,81,73,0.15)' : undefined,
                  display: 'flex', alignItems: 'center', justifyContent: 'center',
                  position: 'relative', padding: '18px 24px', minHeight: 64,
                  fontSize: '1.1rem', lineHeight: 1.9,
                }}
              >
                <span style={{
                  position: 'absolute', left: 18, top: '50%', transform: 'translateY(-50%)',
                  fontWeight: 700, opacity: 0.6, fontSize: '0.95rem',
                }}>{CH12_OPTION_LABEL[displayIdx]}.</span>
                <span style={{ display: 'inline-flex', alignItems: 'center' }}>{ch12RenderMath(opt)}</span>
              </button>
            )
          })}
        </div>
      ) : (
        <>
          <input
            ref={inputRef}
            type="text"
            value={fillInput}
            onChange={e => setFillInput(e.target.value)}
            disabled={revealed}
            placeholder="Your answer…"
            autoComplete="off"
            style={{
              width: '100%', padding: '14px 16px', fontSize: '1.15rem', borderRadius: 8,
              border: '1px solid var(--clr-border, #555)', textAlign: 'center',
              background: revealed ? 'rgba(255,255,255,0.04)' : 'var(--clr-surface, #1c1c1f)',
              color: 'var(--clr-text)', boxSizing: 'border-box',
            }}
          />
          {!revealed && (
            <div style={{ display: 'flex', gap: 8, marginTop: 12, justifyContent: 'center' }}>
              <button onClick={submitFill} disabled={!fillInput.trim()} style={{
                padding: '10px 22px', borderRadius: 6, background: 'var(--clr-accent, #2ea043)',
                color: 'white', border: 'none', cursor: 'pointer', fontSize: '0.95rem',
                opacity: fillInput.trim() ? 1 : 0.5,
              }}>Check</button>
            </div>
          )}
        </>
      )}

      {revealed && (
        <>
          <div style={{
            marginTop: 16, padding: 16, borderRadius: 8,
            background: isCorrect ? 'rgba(46,160,67,0.15)' : 'rgba(248,81,73,0.15)',
            border: `1px solid ${isCorrect ? 'rgba(46,160,67,0.45)' : 'rgba(248,81,73,0.45)'}`,
            fontSize: '1rem', lineHeight: 1.9,
          }}>
            <strong>{isCorrect ? '✅ Correct!' : '❌ Not quite.'}</strong>
            <div style={{ marginTop: 8, display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 6 }}>
              <strong>Answer:</strong>
              <span>{currentQ.kind === 'mcq'
                ? ch12RenderMath(currentQ.options[currentQ.correct])
                : ch12RenderMath(String(currentQ.answer))}</span>
            </div>
            {currentQ.solution && (
              <div style={{ marginTop: 8, opacity: 0.9, display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 6 }}>
                <strong>Working:</strong>
                <span>{ch12RenderMath(currentQ.solution)}</span>
              </div>
            )}
          </div>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12, marginTop: 14, justifyContent: 'center' }}>
            <button onClick={advance} style={{
              padding: '12px 28px', borderRadius: 8, background: 'var(--clr-accent, #2ea043)',
              color: 'white', border: 'none', cursor: 'pointer', fontSize: '1rem', fontWeight: 600,
            }}>
              {qIdx + 1 === lesson.questions.length ? 'Finish lesson →' : 'Next →'}
            </button>
            <span style={{ fontSize: '0.85rem', opacity: 0.65 }}>
              auto-advance in {autoCountdown}s · or press <kbd style={{ padding: '1px 6px', border: '1px solid var(--clr-border, #555)', borderRadius: 4, fontSize: '0.78rem' }}>Enter</kbd>
            </span>
          </div>
        </>
      )}
    </div>
  )
}

/* =====================================================================
 *  Chapter13App — Cambridge IGCSE Chapter 13 (Straight Lines Sequences, Surds and Sets Quadratic Equations)
 *
 *  Mounted at /chapter9. Same UX as Chapter5App–Chapter8App: ordered
 *  chain of lessons, every one unlocked from the start, slider to jump
 *  questions, MCQ with 1-9 keys + fill-in fallbacks, 5s auto-advance,
 *  completed lessons go green (with readable text), wrong answers
 *  appended to END of playList. See Tenali/skills/igcse-chapter/SKILL.md
 *  for the full pattern.
 * ===================================================================== */

const CH13_OPTION_LABEL = ['1','2','3','4','5','6','7','8','9']

function ch13_seededShuffle(n, key) {
  let h = 2166136261
  for (let i = 0; i < key.length; i++) { h ^= key.charCodeAt(i); h = Math.imul(h, 16777619) }
  const rand = () => { h = Math.imul(h ^ (h >>> 15), 2246822507); h = Math.imul(h ^ (h >>> 13), 3266489909); return ((h ^= h >>> 16) >>> 0) / 4294967295 }
  const arr = Array.from({ length: n }, (_, i) => i)
  for (let i = n - 1; i > 0; i--) { const j = Math.floor(rand() * (i + 1)); [arr[i], arr[j]] = [arr[j], arr[i]] }
  return arr
}

function ch13_gcd(a, b) { a = Math.abs(a); b = Math.abs(b); while (b) { [a, b] = [b, a % b] } return a || 1 }
function ch13_reduce(n, d) {
  if (d === 0) return null
  if (d < 0) { n = -n; d = -d }
  const g = ch13_gcd(n, d)
  return { n: n / g, d: d / g }
}
function ch13_parseFrac(raw) {
  if (raw == null) return null
  let s = String(raw).trim().replace(/\\frac\{(-?\d+)\}\{(-?\d+)\}/g, '$1/$2').replace(/\s+/g, ' ').replace(/–/g, '-')
  if (!s) return null
  const mixed = s.match(/^(-?)(\d+)\s+(\d+)\s*\/\s*(\d+)$/)
  if (mixed) {
    const sign = mixed[1] === '-' ? -1 : 1
    const w = +mixed[2], n = +mixed[3], d = +mixed[4]
    if (d === 0) return null
    return ch13_reduce(sign * (w * d + n), d)
  }
  const frac = s.match(/^(-?\d+)\s*\/\s*(-?\d+)$/)
  if (frac) {
    const n = +frac[1], d = +frac[2]
    if (d === 0) return null
    return ch13_reduce(n, d)
  }
  const num = Number(s)
  if (Number.isFinite(num)) {
    if (Number.isInteger(num)) return { n: num, d: 1 }
    const sign = num < 0 ? -1 : 1
    const decimals = (s.split('.')[1] || '').length
    const denom = Math.pow(10, decimals)
    return ch13_reduce(sign * Math.round(Math.abs(num) * denom), denom)
  }
  return null
}
function ch13_fracEqual(a, b) { return a && b && a.n === b.n && a.d === b.d }
function ch13_normalizeNumStr(s) {
  return String(s).trim().replace(/[$,\s%]/g, '').replace(/–/g, '-')
}
function ch13_numEqual(user, expected, tol) {
  const u = parseFloat(ch13_normalizeNumStr(user))
  if (!Number.isFinite(u)) return false
  const t = tol != null ? tol : Math.max(0.005, Math.abs(expected) * 0.005)
  return Math.abs(u - expected) <= t
}

function ch13_checkFill(q, raw) {
  if (!raw || !raw.trim()) return false
  switch (q.kind) {
    case 'fill-num': return ch13_numEqual(raw, q.answer, q.tol)
    case 'fill-frac': {
      const u = ch13_parseFrac(raw)
      const e = ch13_parseFrac(q.answer)
      return ch13_fracEqual(u, e)
    }
    case 'fill-text': return raw.trim().toLowerCase() === String(q.answer).trim().toLowerCase()
    default: return false
  }
}

// --- Lesson catalogue ---------------------------------------------------
// Cambridge IGCSE Chapter 13 — Straight Lines Sequences, Surds and Sets Quadratic Equations
// Sections covered: 13.1 Units (length, mass, capacity, area/volume); 13.2 Time (12/24-hour, durations, timetables); 13.3 Limits of accuracy and bounds; 13.4 Conversion graphs; 13.5 Currency. See uploads PDF p. 412-438.
// nth terms, special sequences, subscript notation); 9.2 Rational and
// irrational numbers (inc. recurring decimals → fractions); 9.3 Surds
// (simplify, +/-, ×/÷, rationalise); 9.4 Sets (notation, ∪/∩/⊂, Venn,
// set builder). See uploads PDF p. 265-311.
const CH13_LESSONS = [
  {
    id: 'L1',
    title: 'Lesson 1 · Metric units of length',
    teach: {
      heading: 'mm \\u2194 cm \\u2194 m \\u2194 km',
      body: [
        'The metric system uses powers of 10 to relate units.',
        '1 cm = 10 mm; 1 m = 100 cm = 1000 mm; 1 km = 1000 m.',
        'TO BIGGER unit (e.g. cm \\to m): DIVIDE by the conversion factor.',
        'TO SMALLER unit (e.g. m \\to cm): MULTIPLY by the conversion factor.',
        'Useful prefixes: kilo (×1000), centi (÷100), milli (÷1000), micro (÷1 000 000).',
      ],
      example: '5 km = 5 × 1000 = 5000 m = 5000 × 100 = 500 000 cm.',
    },
    questions: [
      { kind: 'mcq', prompt: '4 kg = ? g',
        options: ['4000', '400', '40', '0.004'], correct: 0,
        solution: '× 1000.' },
      { kind: 'mcq', prompt: '81 mm = ? cm',
        options: ['8.1', '0.81', '810', '8100'], correct: 0,
        solution: '÷ 10.' },
      { kind: 'mcq', prompt: '2.1 m = ? cm',
        options: ['210', '21', '2100', '0.021'], correct: 0,
        solution: '× 100.' },
      { kind: 'mcq', prompt: '202 cm = ? m',
        options: ['2.02', '0.202', '20.2', '20 200'], correct: 0,
        solution: '÷ 100.' },
      { kind: 'mcq', prompt: '3 cm 5 mm = ? mm',
        options: ['35', '8', '305', '53'], correct: 0,
        solution: '30 + 5.' },
      { kind: 'fill-num', prompt: '5 km = ? m', answer: 5000,
        solution: '× 1000.' },
      { kind: 'fill-num', prompt: '750 cm = ? m', answer: 7.5,
        solution: '÷ 100.' },
      { kind: 'mcq', prompt: '14.21 cm = ? mm',
        options: ['142.1', '14210', '1.421', '0.1421'], correct: 0,
        solution: '× 10.' },
      { kind: 'mcq', prompt: 'Length 19.06 m, give in cm.',
        options: ['1906', '19060', '190.6', '0.1906'], correct: 0,
        solution: '× 100.' },
      { kind: 'mcq', prompt: 'Which is longest: 1.5 m, 200 cm, 1 800 mm?',

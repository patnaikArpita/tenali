      { kind: 'mcq', prompt: 'Big cone 1000 cm^3, small cone 125 cm^3 (similar). Linear ratio (small : big)?',
        options: ['1 : 2', '1 : 8', '1 : 4', '5 : 10'], correct: 0,
        solution: '\\sqrt[3]{125/1000} = 1/2.' },
      { kind: 'mcq', prompt: 'Volume ratio 8 : 27. Linear ratio?',
        options: ['2 : 3', '8 : 27', '4 : 9', '\\sqrt{8} : \\sqrt{27}'], correct: 0,
        solution: 'Cube roots.' },

      { kind: 'fill-std', prompt: '(5 \\times 10^-3) - (1.5 \\times 10^-4)', answer: '4.85x10^-3',
        solution: '1.5 \\times 10^-4 = 0.15 \\times 10^-3; 5 - 0.15 = 4.85.' },
      { kind: 'mcq', prompt: '(3 \\times 10^5) + (4 \\times 10^5)',

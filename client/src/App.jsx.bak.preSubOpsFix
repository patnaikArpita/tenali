      { kind: 'mcq', prompt: 'Is 0 rational or irrational?',
        options: ['Rational', 'Irrational', 'Neither', 'Both'], correct: 0,
        solution: '0 = \\frac{0}{1}.' },
      { kind: 'mcq', prompt: 'Is \\sqrt{16} \\times \\sqrt{9} rational?',
        options: ['Yes — equals 12', 'No', 'Cannot tell', 'Only if rounded'], correct: 0,
        solution: '4 \\times 3 = 12.' },

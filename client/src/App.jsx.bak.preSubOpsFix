      { kind: 'mcq', prompt: 'Same cuboid. Angle between space diagonal and base (1 d.p.)?',
        options: ['45.0°', '36.9°', '53.1°', '60.0°'], correct: 0,
        solution: 'tan^{-1}(5/5).' },
      { kind: 'mcq', prompt: 'Square-based pyramid with base side 6 and apex 4 above the centre. Height of triangle face from base midpoint?',
        options: ['5 (slant height)', '4', '6', '\\sqrt{52}'], correct: 0,
        solution: '\\sqrt{4^2 + 3^2} = 5.' },
      { kind: 'mcq', prompt: 'Same pyramid. Slant edge length (apex to base corner)?',
        options: ['\\sqrt{34}', '\\sqrt{52}', '\\sqrt{20}', '\\sqrt{16}'], correct: 0,
        solution: 'Half-diagonal of base = 3\\sqrt{2}; slant edge = \\sqrt{(3\\sqrt{2})^2 + 4^2} = \\sqrt{18 + 16} = \\sqrt{34}.' },
      { kind: 'mcq', prompt: 'Cube of side 1 — angle of space diagonal to a face?',
        options: ['tan^{-1}(1/\\sqrt{2}) ≈ 35.26°', '45°', '60°', '30°'], correct: 0,
        solution: 'Diagonal of face = \\sqrt{2}; height 1; tan = 1/\\sqrt{2}.' },
      { kind: 'mcq', prompt: 'A 5 m flagpole on top of a 30 m cliff. Distance from base of cliff to a point on horizontal ground where elevation of flagpole top is 50°?',
        options: ['(30+5)/tan 50° ≈ 29.4 m', '30 / tan 50°', '5 / tan 50°', 'Cannot calculate'], correct: 0,
        solution: '35 / tan 50° ≈ 29.37 m.' },
      { kind: 'mcq', prompt: 'A box 2 × 3 × 6. Longest space diagonal?',

  // ───────────────────── L10: Length & midpoint ────────────────────────
  {
    id: 'L10',
    title: 'Lesson 10 · Length & midpoint of a line segment',
    teach: {
      heading: 'Length by Pythagoras; midpoint by averaging',
      body: [
        'Given two points (x_1, y_1) and (x_2, y_2):',
        'LENGTH of the segment = \\sqrt{(x_2 - x_1)^2 + (y_2 - y_1)^2} (Pythagoras on the right triangle whose legs are the x and y differences).',
        'MIDPOINT = (\\frac{x_1 + x_2}{2}, \\frac{y_1 + y_2}{2}) — average each coordinate.',
        'Watch the sign-handling for negative coordinates: (x_2 - x_1) might be negative, but it is squared so the length is still positive.',
        'A common surprise: the midpoint of a segment with positive endpoints can have positive or zero coordinates; with mixed-sign endpoints can lie at the origin.',
      ],
      example: '(1, 2) and (4, 6). Length = \\sqrt{(4-1)^2 + (6-2)^2} = \\sqrt{9 + 16} = \\sqrt{25} = 5. Midpoint = (\\frac{1+4}{2}, \\frac{2+6}{2}) = (2.5, 4).',
    },
    questions: [
      { kind: 'mcq', prompt: 'Length of segment from (0, 0) to (3, 4)?',
        options: ['5', '7', '\\sqrt{7}', '12'], correct: 0,
        solution: '\\sqrt{9+16} = 5.' },
      { kind: 'mcq', prompt: 'Length of segment from (1, 1) to (4, 5)?',
        options: ['5', '7', '\\sqrt{7}', '\\sqrt{17}'], correct: 0,
        solution: '\\sqrt{9+16} = \\sqrt{25} = 5.' },
      { kind: 'mcq', prompt: 'Midpoint of (2, 4) and (8, 10)?',
        options: ['(5, 7)', '(10, 14)', '(6, 6)', '(3, 5)'], correct: 0,
        solution: 'Average each coord.' },
      { kind: 'mcq', prompt: 'Midpoint of (-1, 5) and (3, -1)?',
        options: ['(1, 2)', '(2, 4)', '(2, 2)', '(1, 4)'], correct: 0,
        solution: '(\\frac{-1+3}{2}, \\frac{5+(-1)}{2}) = (1, 2).' },
      { kind: 'mcq', prompt: 'Length of segment from (-2, 3) to (2, 0)?',
        options: ['5', '\\sqrt{7}', '7', '4'], correct: 0,
        solution: '\\sqrt{16+9} = 5.' },
      { kind: 'mcq', prompt: 'Midpoint of (0, 0) and (10, 6)?',
        options: ['(5, 3)', '(10, 6)', '(0, 0)', '(6, 5)'], correct: 0,
        solution: 'Halve each.' },
      { kind: 'mcq', prompt: 'Length from (1, 2) to (7, 10)?',
        options: ['10', '\\sqrt{14}', '14', '8'], correct: 0,
        solution: '\\sqrt{36 + 64} = \\sqrt{100} = 10.' },
      { kind: 'fill-num', prompt: 'Length of segment from (0, 0) to (5, 12).', answer: 13,
        solution: '\\sqrt{25 + 144} = 13.' },
      { kind: 'mcq', prompt: 'Midpoint of (-3, -7) and (5, 1)?',
        options: ['(1, -3)', '(2, -4)', '(-1, -3)', '(8, 8)'], correct: 0,
        solution: '(\\frac{-3+5}{2}, \\frac{-7+1}{2}) = (1, -3).' },
      { kind: 'fill-num', prompt: 'Length from (2, 3) to (5, 7).', answer: 5,
        solution: '\\sqrt{9 + 16} = 5.' },
    ],

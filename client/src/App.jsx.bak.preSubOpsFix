  // ───────────────────── L9: Recurring decimals → fractions ────────────
  {
    id: 'L9',
    title: 'Lesson 9 · Recurring decimals \\to fractions',
    teach: {
      heading: 'The 10x trick',
      body: [
        'Every RECURRING decimal can be written exactly as a fraction. The trick uses simple algebra.',
        'Step 1: Let x equal the recurring decimal.',
        'Step 2: Multiply x by 10, 100, or 1000 (whatever shifts a complete cycle of recurring digits past the decimal point).',
        'Step 3: Subtract the original x. The recurring tails cancel.',
        'Step 4: Solve for x as a fraction.',
        'For one recurring digit, multiply by 10. For two recurring digits, multiply by 100. For three, multiply by 1000.',
      ],
      example: 'x = 0.3333…; 10x = 3.3333…; subtract: 9x = 3 → x = \\frac{3}{9} = \\frac{1}{3}.',
    },
    questions: [
      { kind: 'fill-frac', prompt: 'Convert 0.4444… (the 4 recurs) to a simplified fraction.', answer: '4/9',
        solution: '10x - x = 4 \\to 9x = 4 \\to x = \\frac{4}{9}.' },
      { kind: 'fill-frac', prompt: 'Convert 0.5555… (the 5 recurs) to a simplified fraction.', answer: '5/9',
        solution: 'Same trick: 9x = 5.' },
      { kind: 'fill-frac', prompt: 'Convert 0.1111… (the 1 recurs) to a simplified fraction.', answer: '1/9',
        solution: '9x = 1.' },
      { kind: 'fill-frac', prompt: 'Convert 0.6666… (the 6 recurs) to a simplified fraction.', answer: '2/3',
        solution: '9x = 6 \\to x = \\frac{6}{9} = \\frac{2}{3}.' },
      { kind: 'fill-frac', prompt: 'Convert 0.2424… (the 24 recurs) to a simplified fraction.', answer: '8/33',
        solution: '100x - x = 24 \\to 99x = 24 \\to x = \\frac{24}{99} = \\frac{8}{33}.' },
      { kind: 'fill-frac', prompt: 'Convert 0.3636… (the 36 recurs) to a simplified fraction.', answer: '4/11',
        solution: '99x = 36 \\to x = \\frac{36}{99} = \\frac{4}{11}.' },
      { kind: 'fill-frac', prompt: 'Convert 0.9999… (the 9 recurs) to a simplified fraction.', answer: '1/1',
        solution: '9x = 9 \\to x = 1. (Yes, 0.9 recurring equals exactly 1.)' },
      { kind: 'mcq', prompt: 'Which fraction is 0.272727… (27 recurs) equal to?',
        options: ['\\frac{3}{11}', '\\frac{27}{100}', '\\frac{1}{4}', '\\frac{27}{99}'], correct: 0,
        solution: '99x = 27 \\to x = \\frac{27}{99} = \\frac{3}{11}.' },
      { kind: 'mcq', prompt: 'Convert 0.142857142857… (142857 recurs) to a fraction.',
        options: ['\\frac{1}{7}', '\\frac{1}{6}', '\\frac{1}{8}', '\\frac{142857}{1000000}'], correct: 0,
        solution: 'Famous recurring decimal of \\frac{1}{7}.' },
      { kind: 'mcq', prompt: 'Convert 0.6 (with the 6 recurring) to a fraction.',
        options: ['\\frac{2}{3}', '\\frac{6}{9}', 'Both A and B', '\\frac{3}{5}'], correct: 2,
        solution: '\\frac{6}{9} = \\frac{2}{3}, both correct.' },
    ],
  },

  // ───────────────────── L10: Simplifying surds ────────────────────────

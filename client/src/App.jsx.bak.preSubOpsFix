      { kind: 'mcq', prompt: '7\\sqrt{5} - 2\\sqrt{5} = ?',
        options: ['5\\sqrt{5}', '5\\sqrt{0}', '\\sqrt{5}', '5'], correct: 0,
        solution: 'Subtract coefficients: 7 - 2 = 5.' },
      { kind: 'mcq', prompt: '\\sqrt{8} + \\sqrt{2} = ? (simplify first!)',
        options: ['3\\sqrt{2}', '\\sqrt{10}', '2\\sqrt{2}', 'Cannot combine'], correct: 0,
        solution: '\\sqrt{8} = 2\\sqrt{2}, then 2\\sqrt{2} + \\sqrt{2} = 3\\sqrt{2}.' },

  // ───────────────────── L6: Finding the equation ──────────────────────
  {
    id: 'L6',
    title: 'Lesson 6 · Finding the equation of a line',
    teach: {
      heading: 'Two routes: m and a point, OR two points',
      body: [
        'Given GRADIENT m and Y-INTERCEPT c: write y = mx + c directly.',
        'Given GRADIENT m and ONE POINT (x_1, y_1): substitute into y = mx + c to find c. y_1 = m x_1 + c \\to c = y_1 - m x_1.',
        'Given TWO POINTS: first compute m using m = \\frac{y_2 - y_1}{x_2 - x_1}, then use either point as above to find c.',
        'Given the line is PARALLEL to a known line: copy the gradient (parallel lines have equal m), then use the given point to find c.',
      ],
      example: 'Line passes through (2, 7) with gradient 3. y = 3x + c \\to 7 = 3(2) + c \\to c = 1. Equation: y = 3x + 1.',
    },
    questions: [
      { kind: 'mcq', prompt: 'Line with gradient 2 and y-intercept 5. Equation?',
        options: ['y = 2x + 5', 'y = 5x + 2', '2x + 5y = 0', 'y = 2x - 5'], correct: 0,
        solution: 'Plug into y = mx + c.' },
      { kind: 'mcq', prompt: 'Line with gradient -3 and y-intercept 2. Equation?',
        options: ['y = -3x + 2', 'y = 3x - 2', 'y = -2x + 3', 'y = -3x - 2'], correct: 0,
        solution: 'm = -3, c = 2.' },
      { kind: 'mcq', prompt: 'Line through (0, 4) with gradient 5. Equation?',
        options: ['y = 5x + 4', 'y = 4x + 5', 'y = 5x - 4', 'y = x + 4'], correct: 0,
        solution: '(0, 4) \\to c = 4.' },
      { kind: 'mcq', prompt: 'Line through (1, 5) with gradient 2. y-intercept?',
        options: ['3', '5', '7', '2'], correct: 0,
        solution: '5 = 2(1) + c \\to c = 3.' },
      { kind: 'mcq', prompt: 'Line through (2, 7) with gradient 3. Equation?',
        options: ['y = 3x + 1', 'y = 3x + 7', 'y = 2x + 3', 'y = 3x - 1'], correct: 0,
        solution: '7 = 3(2) + c \\to c = 1.' },
      { kind: 'mcq', prompt: 'Line through (1, 2) and (3, 8). Gradient?',
        options: ['3', '2', '6', '\\frac{1}{3}'], correct: 0,
        solution: '\\frac{8-2}{3-1} = 3.' },
      { kind: 'mcq', prompt: 'Line through (1, 2) and (3, 8). Equation?',
        options: ['y = 3x - 1', 'y = 3x + 1', 'y = 2x', 'y = 3x'], correct: 0,
        solution: 'm = 3; 2 = 3(1) + c \\to c = -1.' },
      { kind: 'mcq', prompt: 'Line parallel to y = 4x - 2, passing through (0, 1). Equation?',
        options: ['y = 4x + 1', 'y = -4x + 1', 'y = 4x - 2', 'y = x + 1'], correct: 0,
        solution: 'Same gradient 4; new c = 1.' },
      { kind: 'mcq', prompt: 'Line parallel to y = -2x + 5, passing through (3, 1). Equation?',
        options: ['y = -2x + 7', 'y = -2x - 7', 'y = 2x - 5', 'y = -2x + 5'], correct: 0,
        solution: 'm = -2; 1 = -2(3) + c \\to c = 7.' },
      { kind: 'fill-num', prompt: 'Line with gradient 2 through (4, 5). What is the y-intercept c?', answer: -3,
        solution: '5 = 2(4) + c \\to c = -3.' },
    ],
  },


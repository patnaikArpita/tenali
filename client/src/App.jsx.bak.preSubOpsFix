      { kind: 'mcq', prompt: '3\\sqrt{2} + 4\\sqrt{3} = ?',
        options: ['Cannot be combined', '7\\sqrt{5}', '7\\sqrt{6}', '3\\sqrt{2} + 4\\sqrt{3}'], correct: 3,
        solution: 'Different surds — leave as is. (Option D is the unsimplified expression.)' },
      { kind: 'mcq', prompt: '\\sqrt{75} - \\sqrt{12} = ?',
